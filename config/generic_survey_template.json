{
  "survey_metadata": {
    "id": "your_survey_id",
    "title": "Your Survey Title",
    "version": "1.1",
    "objective": "edge"
  },
  "dag_structure": {
    "start_node": "START",
    "completion_terminals": [
      "SURVEY_COMPLETE"
    ],
    "early_exit_terminals": [
      "TERMINATE",
      "INELIGIBLE"
    ],
    "intermediate_terminals": [
      "PARTIAL_COMPLETE"
    ],
    "system_terminals": []
  },
  "path_classification": {
    "optimal_paths": {
      "terminals": ["SURVEY_COMPLETE"],
      "priority": 1,
      "survey_value": "HIGH",
      "methodology_note": "Desired outcome - full survey completion"
    },
    "avoid_paths": {
      "terminals": ["TERMINATE", "INELIGIBLE"],
      "priority": 3,
      "survey_value": "LOW", 
      "methodology_note": "Early termination - minimize in deployment"
    },
    "neutral_paths": {
      "terminals": ["PARTIAL_COMPLETE"],
      "priority": 2,
      "survey_value": "MEDIUM",
      "methodology_note": "Partial completion - acceptable outcome"
    }
  },
  "validation_rules": {
    "allow_terminal_chains": true,
    "require_single_start": true,
    "require_single_ultimate_terminal": true,
    "terminal_naming_patterns": [
      "^SURVEY_COMPLETE$",
      "^[A-Z][A-Z0-9_]*$"
    ]
  },
  "coverage_settings": {
    "max_paths": 100,
    "max_depth": 50,
    "objective": "edge",
    "algorithm": "survey_aware_depth_first_search"
  }
}
