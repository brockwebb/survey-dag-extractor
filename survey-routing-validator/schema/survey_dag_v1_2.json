{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Survey DAG Schema v1.2",
  "description": "Enhanced schema supporting conditional routing logic",
  "version": "1.2.0",
  
  "definitions": {
    "condition": {
      "type": "object",
      "properties": {
        "variable": {
          "type": "string",
          "description": "The variable/question ID to check"
        },
        "operator": {
          "type": "string", 
          "enum": ["equals", "not_equals", "in", "not_in", "greater_than", "less_than"],
          "default": "equals",
          "description": "Comparison operator"
        },
        "value": {
          "oneOf": [
            {"type": "string"},
            {"type": "number"},
            {"type": "array", "items": {"oneOf": [{"type": "string"}, {"type": "number"}]}}
          ],
          "description": "Value(s) to compare against"
        }
      },
      "required": ["variable", "value"],
      "additionalProperties": false
    },
    
    "conditional_edge": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique edge identifier"
        },
        "source": {
          "type": "string",
          "description": "Source node ID"
        },
        "target": {
          "type": "string", 
          "description": "Target node ID"
        },
        "conditions": {
          "type": "array",
          "items": {"$ref": "#/definitions/condition"},
          "description": "All conditions must be true (AND logic)",
          "default": []
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "description": "Evaluation priority (lower numbers first)",
          "default": 0
        },
        "kind": {
          "type": "string",
          "enum": ["sequence", "branch", "terminate"],
          "description": "Type of edge transition"
        },
        "subkind": {
          "type": "string", 
          "enum": ["fallthrough", "conditional", "skip", "terminal_branch"],
          "description": "Specific routing behavior"
        },
        "metadata": {
          "type": "object",
          "properties": {
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Extraction confidence score"
            },
            "extraction_method": {
              "type": "string",
              "enum": ["automated", "manual", "hybrid"],
              "description": "How this edge was created"
            },
            "human_validated": {
              "type": "boolean",
              "description": "Has been reviewed by human validator"
            },
            "condition_text": {
              "type": "string",
              "description": "Original conditional text from survey"
            }
          },
          "additionalProperties": true
        }
      },
      "required": ["id", "source", "target"],
      "additionalProperties": false
    },
    
    "node": {
      "type": "object", 
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique node identifier"
        },
        "type": {
          "type": "string",
          "enum": ["question", "instruction", "terminal", "logic_block"],
          "description": "Node type"
        },
        "text": {
          "type": "string",
          "description": "Display text or question content"
        },
        "block": {
          "type": "string", 
          "description": "Survey section/block name"
        },
        "order_index": {
          "type": "integer",
          "description": "Sequential order in original survey"
        },
        "variable": {
          "type": "string",
          "description": "Variable name for questions"
        },
        "domain": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["single_choice", "multiple_choice", "text", "numeric", "scale", "boolean"],
              "description": "Data type/input method"
            },
            "options": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "value": {"oneOf": [{"type": "string"}, {"type": "number"}]},
                  "label": {"type": "string"}
                },
                "required": ["value", "label"]
              },
              "description": "Available response options"
            },
            "validation": {
              "type": "object",
              "properties": {
                "required": {"type": "boolean"},
                "min_value": {"type": "number"},
                "max_value": {"type": "number"},
                "min_length": {"type": "integer"},
                "max_length": {"type": "integer"}
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["id", "type"],
      "additionalProperties": false
    },
    
    "predicate": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique predicate identifier"
        },
        "conditions": {
          "type": "array", 
          "items": {"$ref": "#/definitions/condition"},
          "description": "Logical conditions (AND logic between items)"
        },
        "logic_operator": {
          "type": "string",
          "enum": ["AND", "OR"],
          "default": "AND",
          "description": "How to combine conditions"
        },
        "ast": {
          "description": "Abstract syntax tree representation",
          "oneOf": [
            {"type": "boolean"},
            {"type": "array"}
          ]
        },
        "complexity": {
          "type": "string", 
          "enum": ["simple", "moderate", "complex"],
          "description": "Complexity assessment"
        },
        "text": {
          "type": "string",
          "description": "Human-readable condition text"
        },
        "depends_on": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Node IDs this predicate depends on"
        },
        "human_validated": {
          "type": "boolean",
          "description": "Has been reviewed by human validator"
        }
      },
      "required": ["id", "conditions"],
      "additionalProperties": false
    }
  },
  
  "type": "object",
  "properties": {
    "survey_dag": {
      "type": "object",
      "properties": {
        "metadata": {
          "type": "object",
          "properties": {
            "id": {"type": "string"},
            "title": {"type": "string"}, 
            "version": {"type": "string"},
            "schema_version": {"type": "string", "const": "1.2"},
            "objective": {
              "type": "string",
              "enum": ["edge", "node", "hybrid"],
              "description": "Focus of extraction"
            },
            "build": {
              "type": "object",
              "properties": {
                "extractor_version": {"type": "string"},
                "extracted_at": {"type": "string", "format": "date-time"},
                "method": {
                  "type": "string", 
                  "enum": ["automated", "manual", "hybrid"],
                  "description": "Extraction method used"
                },
                "source_format": {"type": "string"},
                "validation_passed": {"type": "boolean"},
                "post_edit": {"type": "boolean"},
                "conditional_patterns_detected": {
                  "type": "integer",
                  "description": "Number of conditional routing patterns found"
                }
              },
              "additionalProperties": true
            }
          },
          "required": ["schema_version"],
          "additionalProperties": true
        },
        
        "graph": {
          "type": "object",
          "properties": {
            "start": {
              "type": "string",
              "description": "Starting node ID"
            },
            "terminals": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Terminal node IDs"
            },
            "nodes": {
              "type": "array",
              "items": {"$ref": "#/definitions/node"},
              "description": "All survey nodes"
            },
            "edges": {
              "type": "array", 
              "items": {"$ref": "#/definitions/conditional_edge"},
              "description": "Conditional routing edges"
            }
          },
          "required": ["start", "terminals", "nodes", "edges"],
          "additionalProperties": false
        },
        
        "predicates": {
          "type": "object",
          "patternProperties": {
            "^[A-Z0-9_]+$": {"$ref": "#/definitions/predicate"}
          },
          "description": "Named predicate definitions"
        },
        
        "validation": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["EXTRACTED", "PARTIAL_VALIDATION", "HUMAN_VALIDATED", "FAILED"],
              "description": "Overall validation status"
            },
            "routing_completeness": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Percentage of nodes with complete routing"
            },
            "conditional_accuracy": {
              "type": "number", 
              "minimum": 0,
              "maximum": 1,
              "description": "Estimated accuracy of conditional logic"
            },
            "dead_ends": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Node IDs with no outgoing paths"
            },
            "unreachable_nodes": {
              "type": "array", 
              "items": {"type": "string"},
              "description": "Node IDs that cannot be reached"
            },
            "validation_notes": {
              "type": "object",
              "patternProperties": {
                "^[A-Za-z0-9_]+$": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["not_reviewed", "flagged_for_review", "validated", "issues"]
                    },
                    "note": {"type": "string"},
                    "validated_at": {"type": "string", "format": "date-time"},
                    "validator_id": {"type": "string"}
                  }
                }
              },
              "description": "Per-node validation notes"
            }
          },
          "additionalProperties": true
        }
      },
      "required": ["metadata", "graph"],
      "additionalProperties": false
    }
  },
  "required": ["survey_dag"],
  "additionalProperties": false
}