{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Survey DAG Schema v1.1 - Fixed for Real Survey Patterns",
  "type": "object",
  "required": ["survey_dag"],
  "properties": {
    "survey_dag": {
      "type": "object",
      "required": ["metadata", "graph", "predicates"],
      "properties": {
        "metadata": {
          "type": "object",
          "required": ["id", "title", "version", "objective"],
          "properties": {
            "id": {"type": "string"},
            "title": {"type": "string"},
            "version": {"type": "string"},
            "objective": {"type": "string", "enum": ["edge", "node", "path"]},
            "build": {
              "type": "object",
              "properties": {
                "extractor_version": {"type": "string"},
                "extracted_at": {"type": "string", "format": "date-time"},
                "method": {"type": "string"},
                "source_format": {"type": "string"},
                "validation_passed": {"type": "boolean"},
                "post_edit": {"type": "boolean"}
              }
            }
          }
        },
        "graph": {
          "type": "object",
          "required": ["start", "terminals", "nodes", "edges"],
          "properties": {
            "start": {
              "type": "string",
              "description": "Starting node ID"
            },
            "terminals": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^(SURVEY_COMPLETE|FINAL_TERMINATION|END|END_[A-Z0-9_]+|[A-Z][A-Za-z0-9_]*)$"
              },
              "description": "FIXED: Allow any reasonable terminal naming pattern including R2a, Q1a, etc."
            },
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "type"],
                "properties": {
                  "id": {"type": "string"},
                  "type": {
                    "type": "string",
                    "enum": ["question", "instruction", "terminal", "ultimate_terminal"]
                  },
                  "order_index": {"type": "integer", "minimum": 0},
                  "block": {"type": "string"},
                  "domain": {
                    "type": "object",
                    "properties": {
                      "kind": {"type": "string"},
                      "values": {"type": "array"},
                      "range": {"type": "object"}
                    }
                  },
                  "universe": {
                    "type": "object",
                    "properties": {
                      "expression": {"type": "string"},
                      "dependencies": {"type": "array", "items": {"type": "string"}}
                    }
                  },
                  "variable": {
                    "type": "string",
                    "description": "Optional survey variable name for data dictionary mapping"
                  },
                  "metadata": {"type": "object"}
                }
              }
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "source", "target", "predicate", "kind"],
                "properties": {
                  "id": {"type": "string"},
                  "source": {"type": "string"},
                  "target": {"type": "string"},
                  "predicate": {"type": "string"},
                  "kind": {
                    "type": "string",
                    "enum": ["fallthrough", "branch", "terminate", "skip"]
                  },
                  "priority": {"type": "integer"},
                  "subkind": {"type": "string"}
                }
              }
            }
          }
        },
        "predicates": {
          "type": "object",
          "patternProperties": {
            "^P_[A-Z0-9_]+$": {
              "type": "object",
              "required": ["ast"],
              "properties": {
                "ast": {"type": "array"},
                "complexity": {"type": "string"},
                "text": {"type": "string"}
              }
            }
          }
        },
        "validation": {
          "type": "object",
          "properties": {
            "status": {"type": "string", "enum": ["OK", "OK_WITH_WARNINGS", "FAIL"]},
            "issues": {"type": "array"},
            "gates": {"type": "object"}
          }
        },
        "analysis": {"type": "object"},
        "coverage": {"type": "object"}
      }
    }
  }
}
